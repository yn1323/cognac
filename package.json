{
  "name": "cognac-monorepo",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "pnpm -r --parallel lint",
    "test": "pnpm -r --parallel test",
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @cognac/server --filter @cognac/client dev",
    "storybook": "pnpm -F @cognac/client storybook"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
